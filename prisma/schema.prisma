// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For email/password authentication
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  testSessions  TestSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TestSession {
  id              String   @id @default(cuid())
  userId          String?
  personName      String   @default("Myself")
  isSelf          Boolean  @default(true)
  relation        String?  // e.g. Parent, Child, Spouse, Sibling, Friend, Other
  gender          String?  // e.g. Male, Female, Other, Prefer not to say
  language        String   @default("en")
  answers         String   // JSON string of Answer[]
  score           Int?
  urgency         String?
  factors         String?  // JSON string of Factor[]
  primaryCategory String?
  recommendation  String?
  confidenceScore      Float?
  confidenceLevel      String?
  confidenceExplanation String?
  riskReasoning        String?
  riskSummary          String?  // Groq narrative for "Why this risk level?"
  riskFactors          String?  // JSON string of string[] — bullet factors
  primaryAction        String?  // Groq primary action line
  recommendationSteps  String?  // JSON string of string[] — action steps
  keyInsights          String?  // JSON string of string[]
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id])
}
